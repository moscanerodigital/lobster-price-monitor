[Unit]
Description=Lobster Price Monitor scrape with Telegram alerts (Gate D ops)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=erik
WorkingDirectory=/opt/lobster-price-monitor
Environment=LOBSTER_ALERTS=1
ExecStart=/opt/lobster-price-monitor/scripts/run_scrape.sh
StandardOutput=append:/opt/lobster-price-monitor/logs/scrape.stdout.log
StandardError=append:/opt/lobster-price-monitor/logs/scrape.stderr.log

[Install]
WantedBy=multi-user.target
