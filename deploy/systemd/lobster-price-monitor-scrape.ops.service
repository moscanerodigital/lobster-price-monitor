[Unit]
Description=Lobster Price Monitor scrape with Telegram alerts (Gate D ops)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=erik
WorkingDirectory=LOBSTER_ROOT
Environment=LOBSTER_ALERTS=1
ExecStart=LOBSTER_ROOT/scripts/run_scrape.sh
StandardOutput=append:LOBSTER_ROOT/logs/scrape.stdout.log
StandardError=append:LOBSTER_ROOT/logs/scrape.stderr.log

[Install]
WantedBy=multi-user.target
