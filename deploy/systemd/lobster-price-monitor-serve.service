[Unit]
Description=Lobster Price Monitor board HTTP server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=erik
WorkingDirectory=LOBSTER_ROOT
ExecStart=LOBSTER_ROOT/.venv/bin/python scripts/serve_board.py --port 8765 --host 0.0.0.0
Restart=on-failure
RestartSec=5
StandardOutput=append:LOBSTER_ROOT/logs/serve.log
StandardError=append:LOBSTER_ROOT/logs/serve.err

[Install]
WantedBy=multi-user.target
