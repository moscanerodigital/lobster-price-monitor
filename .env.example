# Environment variables for lobster-price-monitor
# Copy to .env and adjust for your host. Secrets files under ~/.openclaw/secrets/
# remain the primary source for tokens and cookies.

# Install path (used by systemd/launchd units and promote_ops.sh)
# LOBSTER_ROOT=/opt/lobster-price-monitor

# Enable Telegram alerts during scheduled scrapes (ops mode)
# LOBSTER_ALERTS=1

# Telegram chat ID (fallback: ~/.openclaw/secrets/telegram/chat_id)
# LOBSTER_TELEGRAM_CHAT_ID=6700324874

# HTTP board server (make serve)
# PORT=8765
# BIND=0.0.0.0

# Secrets (file-based, not env vars — paths for reference):
#   ~/.openclaw/secrets/telegram/herb.token
#   ~/.openclaw/secrets/telegram/chat_id
#   ~/.openclaw/secrets/facebook-cookies.json
#   ~/.openclaw/secrets/google-cse.key
#   ~/.openclaw/secrets/google-cse.cx
